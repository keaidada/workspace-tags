{
  "manifest_version": 3,
  "name": "Workspace Tags - 文件标签管理器",
  "version": "1.0.0",
  "description": "本地文件标签管理工具，支持标签分类、时间排序和筛选功能",
  "permissions": [
    "storage",
    "unlimitedStorage",
    "nativeMessaging"
  ],
  "action": {
    "default_title": "打开文件标签管理器"
  },
  "background": {
    "service_worker": "background.js"
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.svg",
    "48": "icons/icon48.svg",
    "128": "icons/icon128.svg"
  }
}
